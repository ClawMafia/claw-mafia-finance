{
  "name": "@claw-mafia/claw-mafia-finance",
  "version": "0.1.0",
  "private": true,
  "description": "Structured equity research, backtesting, and paper trading plugin for OpenClaw",
  "type": "module",
  "openclaw": {
    "extensions": [
      "./dist/index.js"
    ]
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc --noEmit",
    "test": "node --test test/*.test.ts",
    "setup-python": "python3 -m venv engine/.venv && engine/.venv/bin/pip install -r engine/requirements.txt"
  },
  "devDependencies": {
    "@sinclair/typebox": "^0.34.0",
    "@types/node": "^25.5.0",
    "openclaw": "file:../openclaw",
    "typescript": "^5.9.0"
  },
  "dependencies": {
    "@stoqey/ib": "^1.5.3",
    "@types/better-sqlite3": "^7.6.13",
    "better-sqlite3": "^12.11.1"
  }
}
