{
  "id": "claw-mafia-finance",
  "name": "Claw Mafia Finance",
  "description": "Structured equity research, backtesting, and paper trading tools for options-based strategies.",
  "version": "0.1.0",
  "configSchema": {
    "type": "object",
    "additionalProperties": false,
    "properties": {
      "alpacaApiKey": {
        "type": "string",
        "description": "Alpaca API key for market data and paper trading"
      },
      "alpacaApiSecret": {
        "type": "string",
        "description": "Alpaca API secret"
      },
      "alpacaBaseUrl": {
        "type": "string",
        "description": "Alpaca trading base URL (default: https://paper-api.alpaca.markets)"
      },
      "fredApiKey": {
        "type": "string",
        "description": "FRED API key for economic data"
      },
      "dataDir": {
        "type": "string",
        "description": "Directory for cached market data",
        "default": "./data"
      },
      "paperAccountCapital": {
        "type": "number",
        "description": "Initial paper trading capital in USD",
        "default": 100000
      }
    },
    "required": ["alpacaApiKey", "alpacaApiSecret"]
  },
  "uiHints": {
    "alpacaApiKey": {
      "label": "Alpaca API Key",
      "help": "Get one at https://app.alpaca.markets/paper-trading",
      "sensitive": true
    },
    "alpacaApiSecret": {
      "label": "Alpaca API Secret",
      "sensitive": true
    },
    "alpacaBaseUrl": {
      "label": "Alpaca Base URL",
      "help": "Use https://paper-api.alpaca.markets for paper trading (default)"
    },
    "fredApiKey": {
      "label": "FRED API Key",
      "help": "Get one at https://fred.stlouisfed.org/docs/api/api_key.html",
      "sensitive": true
    },
    "dataDir": {
      "label": "Data Directory",
      "help": "Local path for caching market data files"
    },
    "paperAccountCapital": {
      "label": "Paper Account Capital",
      "help": "Starting capital for paper trading account (USD)"
    }
  }
}
